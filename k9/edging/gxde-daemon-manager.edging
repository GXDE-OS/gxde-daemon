#!/bin/bash

# 目标程序路径（需要运行的可执行文件或命令）
TARGET_PROCESS="/usr/libexec/gxde-daemon/daemon-manager/gxde-daemon-manager"
# 需要如果 systemd 正在运行就不执行的话，请填写任意字符来启用
# 如启用，若检测到 systemd 正在运行，则直接退出脚本。若不启用则会不检测，继续执行
#
# 此处留空：daemon-manager 不依赖 systemd，交由 k9 统一拉起与守护，
# 以保证无 systemd 的环境（如安卓端）同样可用。
DONT_RUN_IF_SYSTEMD_EXIST=""
