#!/usr/bin/make -f

# See debhelper(7) (uncomment to enable).
# Output every command that modifies files on the build system.
#export DH_VERBOSE = 1

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

DOCK_SRC = plugins/dock
DM_SRC = plugins/daemon-manager
GTK_INJECT_SRC = plugins/gtk-theme-inject
PKGDIR = debian/gxde-daemon

%:
	dh $@

# No CMake project at the repository root; the compiled plugins live in
# subdirectories and are built explicitly below.
override_dh_auto_configure:

override_dh_auto_build:
	cmake -S $(DOCK_SRC) -B $(DOCK_SRC)/build -DCMAKE_BUILD_TYPE=Release
	cmake --build $(DOCK_SRC)/build -j$$(nproc)
	cmake -S $(DM_SRC) -B $(DM_SRC)/build -DCMAKE_BUILD_TYPE=Release
	cmake --build $(DM_SRC)/build -j$$(nproc)
	cmake -S $(GTK_INJECT_SRC) -B $(GTK_INJECT_SRC)/build -DCMAKE_BUILD_TYPE=Release
	cmake --build $(GTK_INJECT_SRC)/build -j$$(nproc)

override_dh_auto_install:
	install -Dm755 $(DOCK_SRC)/build/gxde-dock-daemon \
		$(PKGDIR)/usr/libexec/gxde-daemon/dock/gxde-dock-daemon
	install -Dm755 $(GTK_INJECT_SRC)/build/gxde-gtk-theme-inject \
		$(PKGDIR)/usr/libexec/gxde-daemon/gtk-theme-inject/gxde-gtk-theme-inject
	install -Dm755 $(DM_SRC)/build/gxde-daemon-manager \
		$(PKGDIR)/usr/libexec/gxde-daemon/daemon-manager/gxde-daemon-manager

override_dh_auto_clean:
	rm -rf $(DOCK_SRC)/build $(DM_SRC)/build $(GTK_INJECT_SRC)/build
